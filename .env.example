# Database
DATABASE_URL=postgresql://jarvis:jarvis@localhost:5433/jarvis_dev

# Voice pipeline (OpenAI chained stack)
OPENAI_API_KEY=

# STT/TTS model overrides (optional)
STT_MODEL=whisper-large-v3-turbo
# Optional: ISO 639-1 STT language (e.g. en). Set to reduce wrong-language transcripts when auto-detect mis-guesses on noise.
# STT_LANGUAGE=en
LLM_MODEL=gpt-5.4-nano
TTS_MODEL=tts-1
TTS_VOICE=alloy

# GitHub (server-side only)
GITHUB_TOKEN=

# Optional: pre-select a public repo for new voice sessions (leave blank to let the assistant ask for user + repo)
JARVIS_DEFAULT_GITHUB_REPO_URL=
JARVIS_REPO_DISPLAY_NAME=

# Web search for web_search tool (Tavily — https://tavily.com/ ); unset disables live search
TAVILY_API_KEY=

# Operational API (unset = use fake adapter)
OPERATIONAL_API_BASE_URL=

# Fake adapter mode: normal | empty | error | stale
OPERATIONAL_FAKE_MODE=normal

# Logging
LOG_LEVEL=INFO

# Data retention (days)
RETENTION_DAYS=30

# Admin API key for data deletion endpoint
ADMIN_API_KEY=
